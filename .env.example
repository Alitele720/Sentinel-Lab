# 应用会话密钥，真实部署前请务必修改。
IDS_SECRET_KEY=change-me-before-production

# 服务监听地址和端口。
IDS_HOST=0.0.0.0
IDS_PORT=5000

# 运行时行为。
IDS_PRODUCTION_MODE=true
IDS_START_WATCHER=true
IDS_SYNC_INGEST_REAL_REQUESTS=true

# 管理后台访问控制。
IDS_ADMIN_ALLOWED_IPS=127.0.0.1,::1
IDS_ADMIN_AUTH_ENABLED=true
IDS_ADMIN_USERNAME=admin
IDS_ADMIN_PASSWORD=change-this-password

# 反向代理支持。只有在代理可信时才启用。
IDS_TRUST_PROXY=false
IDS_TRUSTED_PROXY_IPS=

# 实验路由。仅建议在本机或授权演示环境启用。
IDS_EXPOSE_LABS=false

# 真实端口扫描抓包。需要先安装 Npcap，并以管理员权限启动。
IDS_PORTSCAN_CAPTURE_ENABLED=false
IDS_PORTSCAN_CAPTURE_INTERFACE=
IDS_PORTSCAN_CAPTURE_FILTER=tcp
